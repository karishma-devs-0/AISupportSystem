# Optional: Add your API key to use LLM mode (OpenAI, Grok, etc.)
# Leave empty to use FREE mode (TextBlob + keyword matching)

# OpenAI (Get $5 free credits: https://platform.openai.com/signup)
OPENAI_API_KEY=

# Grok/xAI (Free during beta: https://x.ai)
XAI_API_KEY=

# Groq (Free tier: https://console.groq.com)
GROQ_API_KEY=

# AI Mode: "free" or "llm" (defaults to "free" if no API key)
AI_MODE=free
